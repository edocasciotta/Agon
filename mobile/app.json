{
  "expo": {
    "name": "Agon Studio",
    "slug": "agon-studio",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agon.studio"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.agon.studio"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4F46E5"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Agon to scan QR codes to connect to your studio."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Agon to access your photos so you can set a profile picture.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-font"
    ],
    "scheme": "agon"
  }
}
